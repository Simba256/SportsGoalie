# Firebase Configuration (Required)
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin (Required for API routes)
# Generate from Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Setup Secret (Required for admin user setup)
# Generate a secure random string for this value
ADMIN_SETUP_SECRET=your_secure_random_secret_here

# YouTube API (Optional - for video content)
YOUTUBE_API_KEY=your_youtube_api_key

# Anthropic API (Required for chatbot)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend Email Service (Phase B - Custom Email Verification)
# Get API key from https://resend.com after verifying your domain
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@smartergoalie.com

# Environment Configuration
NODE_ENV=development
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Error Tracking (Optional - Production)
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_public_sentry_dsn

# Analytics (Optional - Production)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_google_analytics_id

# Development Features
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
NEXT_PUBLIC_DEBUG_MODE=false
